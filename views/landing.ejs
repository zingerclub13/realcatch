    .county-popup .popup-stat .pval { font-size: 22px; font-weight: 800; color: white; }
    .county-popup .popup-stat .plbl { font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.5px; }
    .county-popup .popup-cta { display: block; background: #4CAF50; color: white; text-align: center; padding: 12px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; transition: background 0.2s; }
