<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RealCatch — AI-Powered Real Estate Lead Intelligence</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a2e; line-height: 1.6; background: #0d0d1a; }

    .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 40px; max-width: 1300px; margin: 0 auto; }
    .nav-logo { font-size: 26px; font-weight: 800; color: white; text-decoration: none; letter-spacing: -0.5px; }
    .nav-logo span { color: #4CAF50; }
    .nav-links { display: flex; align-items: center; gap: 25px; }
    .nav-links a { text-decoration: none; color: rgba(255,255,255,0.7); font-weight: 500; font-size: 15px; }
    .nav-links a.btn { background: #4CAF50; color: white; padding: 10px 22px; border-radius: 6px; font-weight: 600; }

    /* ---- HERO ---- */
    .hero { text-align: center; padding: 70px 20px 30px; background: linear-gradient(180deg, #0d0d1a 0%, #111128 100%); color: white; }
    .hero-badge { display: inline-block; background: rgba(76,175,80,0.15); color: #4CAF50; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; margin-bottom: 20px; border: 1px solid rgba(76,175,80,0.3); }
    .hero h1 { font-size: 52px; max-width: 800px; margin: 0 auto 20px; line-height: 1.1; font-weight: 800; letter-spacing: -1px; }
    .hero h1 em { font-style: normal; color: #4CAF50; }
    .hero p { font-size: 19px; opacity: 0.7; max-width: 600px; margin: 0 auto 35px; }
    .hero-buttons { display: flex; gap: 15px; justify-content: center; margin-bottom: 15px; }
    .hero-cta { display: inline-block; background: #4CAF50; color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
    .hero-cta:hover { background: #43a047; transform: translateY(-1px); }
    .hero-cta-ghost { display: inline-block; border: 1px solid rgba(255,255,255,0.25); color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 600; text-decoration: none; }
    .hero-sub { font-size: 13px; opacity: 0.4; margin-top: 10px; }

    /* ---- LIVE DEMO SECTION ---- */
    .demo-section { padding: 40px 20px 80px; background: linear-gradient(180deg, #111128 0%, #0d0d1a 100%); }
    .demo-section h2 { text-align: center; color: white; font-size: 15px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.4; margin-bottom: 30px; }

    .demo-wrapper { max-width: 1150px; margin: 0 auto; background: #1a1a2e; border-radius: 16px; border: 1px solid rgba(255,255,255,0.08); overflow: hidden; box-shadow: 0 25px 80px rgba(0,0,0,0.5); }

    .demo-topbar { background: #12122a; padding: 14px 25px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .demo-topbar-left { display: flex; align-items: center; gap: 12px; }
    .demo-dots { display: flex; gap: 6px; }
    .demo-dots span { width: 12px; height: 12px; border-radius: 50%; }
    .demo-dots span:nth-child(1) { background: #ff5f57; }
    .demo-dots span:nth-child(2) { background: #ffbd2e; }
    .demo-dots span:nth-child(3) { background: #28c840; }
    .demo-url { background: rgba(255,255,255,0.06); padding: 6px 16px; border-radius: 6px; font-size: 12px; color: rgba(255,255,255,0.4); font-family: monospace; }
    .demo-topbar-right { display: flex; gap: 10px; align-items: center; }
    .demo-tier { background: #4CAF50; padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; color: white; text-transform: uppercase; }
    .demo-user { color: rgba(255,255,255,0.4); font-size: 12px; }

    .demo-body { padding: 25px; }

    /* Stats row */
    .demo-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 25px; }
    .demo-stat { background: rgba(255,255,255,0.04); padding: 18px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.06); }
    .demo-stat .label { color: rgba(255,255,255,0.35); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
    .demo-stat .val { font-size: 32px; font-weight: 800; color: white; margin-top: 4px; }
    .demo-stat .val.green { color: #4CAF50; }
    .demo-stat .val.red { color: #ff5252; }
    .demo-stat .val.amber { color: #ffab00; }
    .demo-stat .change { font-size: 11px; color: #4CAF50; margin-top: 4px; }

    /* Filters */
    .demo-filters { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
    .demo-filter { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); padding: 8px 14px; border-radius: 6px; color: rgba(255,255,255,0.5); font-size: 13px; cursor: pointer; transition: all 0.2s; user-select: none; }
    .demo-filter:hover { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .demo-filter.active { background: rgba(76,175,80,0.12); border-color: rgba(76,175,80,0.3); color: #4CAF50; }

    /* Lead table */
    .demo-table { width: 100%; border-collapse: collapse; }
    .demo-table th { text-align: left; padding: 10px 14px; color: rgba(255,255,255,0.3); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.06); font-weight: 600; }
    .demo-table td { padding: 14px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top; }
    .demo-table tr { transition: all 0.25s ease; }
    .demo-table tr:hover { background: rgba(255,255,255,0.02); }
    .demo-table tr.hidden-row { display: none; }

    .score-badge { display: inline-block; padding: 5px 14px; border-radius: 20px; font-weight: 800; color: white; font-size: 15px; min-width: 50px; text-align: center; }
    .score-hot { background: linear-gradient(135deg, #ff1744, #d50000); box-shadow: 0 2px 12px rgba(255,23,68,0.3); }
    .score-warm { background: linear-gradient(135deg, #ff9100, #ff6d00); box-shadow: 0 2px 12px rgba(255,145,0,0.3); }
    .score-cool { background: linear-gradient(135deg, #4CAF50, #2e7d32); box-shadow: 0 2px 12px rgba(76,175,80,0.3); }

    .lead-type { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .lt-foreclosure { background: rgba(255,23,68,0.12); color: #ff5252; }
    .lt-tax { background: rgba(255,145,0,0.12); color: #ffab00; }
    .lt-absentee { background: rgba(33,150,243,0.12); color: #42a5f5; }
    .lt-undervalued { background: rgba(156,39,176,0.12); color: #ba68c8; }

    .addr { color: white; font-weight: 600; font-size: 14px; }
    .addr-sub { color: rgba(255,255,255,0.35); font-size: 12px; margin-top: 2px; }
    .owner { color: rgba(255,255,255,0.6); font-size: 13px; }
    .owner-flag { color: #42a5f5; font-size: 11px; }
    .value { color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 600; }
    .summary { color: rgba(255,255,255,0.45); font-size: 12px; line-height: 1.5; max-width: 280px; }
    .ai-tag { display: inline-block; background: rgba(76,175,80,0.1); color: #4CAF50; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 3px; margin-bottom: 4px; letter-spacing: 0.5px; }

    .signals-row { display: flex; gap: 5px; margin-top: 6px; flex-wrap: wrap; }
    .signal-pill { display: inline-block; background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); padding: 2px 8px; border-radius: 3px; font-size: 10px; }

    /* Blurred overlay for locked leads */
    .locked-row td { position: relative; }
    .locked-row .addr, .locked-row .owner, .locked-row .value, .locked-row .summary { filter: blur(5px); user-select: none; }
    .unlock-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; text-align: center; }
    .unlock-btn { background: #4CAF50; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-weight: 700; font-size: 12px; cursor: pointer; white-space: nowrap; }

    /* ---- EMAIL PREVIEW ---- */
    .email-demo-section { padding: 80px 20px; background: #0d0d1a; }
    .email-demo-section > h2 { text-align: center; color: white; font-size: 36px; margin-bottom: 15px; }
    .email-demo-section > p { text-align: center; color: rgba(255,255,255,0.5); margin-bottom: 40px; font-size: 17px; }

    .email-preview { max-width: 620px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
    .email-header { background: #1a1a2e; color: white; padding: 22px 28px; }
    .email-header h3 { margin: 0 0 3px; font-size: 20px; }
    .email-header p { margin: 0; opacity: 0.6; font-size: 13px; }
    .email-body { padding: 25px 28px; }
    .email-lead { display: flex; justify-content: space-between; align-items: flex-start; padding: 16px 0; border-bottom: 1px solid #f0f0f0; }
    .email-lead:last-child { border: none; }
    .email-lead-info h4 { font-size: 15px; margin-bottom: 3px; color: #1a1a2e; }
    .email-lead-info p { font-size: 13px; color: #666; margin: 0; }
    .email-lead-score { text-align: center; flex-shrink: 0; margin-left: 15px; }
    .email-lead-score .num { font-size: 28px; font-weight: 800; }
    .email-lead-score .num.hot { color: #e53935; }
    .email-lead-score .num.warm { color: #ff9800; }
    .email-lead-score .lbl { font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; }
    .email-cta { display: block; text-align: center; background: #4CAF50; color: white; padding: 14px; border-radius: 8px; text-decoration: none; font-weight: 700; margin-top: 15px; font-size: 15px; }

    /* ---- HOW IT WORKS ---- */
    .how-section { padding: 80px 20px; background: #111128; }
    .how-section h2 { text-align: center; color: white; font-size: 36px; margin-bottom: 60px; }
    .how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1000px; margin: 0 auto; }
    .how-card { text-align: center; padding: 35px 25px; background: rgba(255,255,255,0.03); border-radius: 14px; border: 1px solid rgba(255,255,255,0.06); }
    .how-num { width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, #4CAF50, #2e7d32); color: white; font-size: 22px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
    .how-card h3 { color: white; margin-bottom: 10px; font-size: 18px; }
    .how-card p { color: rgba(255,255,255,0.45); font-size: 14px; }

    /* ---- DATA SOURCES ---- */
    .sources { padding: 60px 20px; background: #0d0d1a; text-align: center; }
    .sources h2 { color: white; font-size: 15px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.3; margin-bottom: 25px; }
    .source-logos { display: flex; justify-content: center; gap: 50px; flex-wrap: wrap; align-items: center; }
    .source-item { color: rgba(255,255,255,0.2); font-size: 14px; font-weight: 600; padding: 12px 20px; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; }

    /* ---- PRICING ---- */
    .pricing { padding: 80px 20px; background: #111128; }
    .pricing h2 { text-align: center; color: white; font-size: 36px; margin-bottom: 15px; }
    .pricing .subtitle { text-align: center; color: rgba(255,255,255,0.4); margin-bottom: 50px; font-size: 16px; }
    .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 950px; margin: 0 auto; }
    .price-card { background: rgba(255,255,255,0.03); padding: 35px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.06); position: relative; }
    .price-card.featured { border-color: #4CAF50; background: rgba(76,175,80,0.06); }
    .price-card.featured::before { content: 'MOST POPULAR'; position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #4CAF50; color: white; font-size: 10px; font-weight: 800; padding: 4px 14px; border-radius: 10px; letter-spacing: 1px; }
    .price-card h3 { font-size: 20px; color: white; margin-bottom: 5px; }
    .price-card .price { font-size: 44px; font-weight: 800; color: white; margin: 15px 0; }
    .price-card .price span { font-size: 16px; opacity: 0.4; font-weight: 400; }
    .price-card ul { list-style: none; margin: 20px 0 30px; }
    .price-card li { padding: 7px 0; font-size: 14px; color: rgba(255,255,255,0.6); }
    .price-card li::before { content: '✓ '; color: #4CAF50; font-weight: bold; }
    .price-card a { display: block; text-align: center; padding: 14px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 15px; }
    .price-card a.primary { background: #4CAF50; color: white; }
    .price-card a.ghost { border: 1px solid rgba(255,255,255,0.15); color: white; }

    /* ---- CTA ---- */
    .cta-bottom { text-align: center; padding: 80px 20px; background: #0d0d1a; }
    .cta-bottom h2 { font-size: 40px; color: white; margin-bottom: 15px; }
    .cta-bottom p { color: rgba(255,255,255,0.45); margin-bottom: 30px; font-size: 18px; }

    .footer { text-align: center; padding: 30px; color: rgba(255,255,255,0.2); font-size: 13px; background: #0d0d1a; border-top: 1px solid rgba(255,255,255,0.05); }

    @media (max-width: 900px) {
      .demo-stats { grid-template-columns: repeat(2, 1fr); }
      .price-grid, .how-grid { grid-template-columns: 1fr; max-width: 400px; }
    }
    @media (max-width: 768px) {
      .hero h1 { font-size: 34px; }
      .nav { padding: 15px 20px; }
      .nav-links { gap: 12px; }
      .nav-links a { font-size: 13px; }
      .hero-buttons { flex-direction: column; align-items: center; }
      .demo-stats { grid-template-columns: 1fr 1fr; }
      .demo-table { font-size: 12px; }
    }
  </style>
</head>
