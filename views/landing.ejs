<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RealCatch — AI-Powered Real Estate Lead Intelligence</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #e0e0e0; line-height: 1.6; background: #0d0d1a; }
    a { color: inherit; }

    /* NAV */
    .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 40px; max-width: 1300px; margin: 0 auto; }
    .nav-logo { font-size: 26px; font-weight: 800; color: white; text-decoration: none; letter-spacing: -0.5px; }
    .nav-logo span { color: #4CAF50; }
    .nav-links { display: flex; align-items: center; gap: 25px; }
    .nav-links a { text-decoration: none; color: rgba(255,255,255,0.7); font-weight: 500; font-size: 15px; }
    .nav-links a.btn { background: #4CAF50; color: white; padding: 10px 22px; border-radius: 6px; font-weight: 600; }

    /* HERO */
    .hero { text-align: center; padding: 70px 20px 30px; background: linear-gradient(180deg, #0d0d1a 0%, #111128 100%); color: white; }
    .beta-badge { display: inline-block; background: rgba(255,171,0,0.15); color: #ffab00; padding: 6px 18px; border-radius: 20px; font-size: 13px; font-weight: 700; margin-bottom: 20px; border: 1px solid rgba(255,171,0,0.35); letter-spacing: 0.5px; }
    .hero h1 { font-size: 52px; max-width: 850px; margin: 0 auto 20px; line-height: 1.1; font-weight: 800; letter-spacing: -1px; }
    .hero h1 em { font-style: normal; color: #4CAF50; }
    .hero p.sub { font-size: 19px; opacity: 0.6; max-width: 640px; margin: 0 auto 35px; }
    .hero-buttons { display: flex; gap: 15px; justify-content: center; margin-bottom: 15px; }
    .hero-cta { display: inline-block; background: #4CAF50; color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
    .hero-cta:hover { background: #43a047; transform: translateY(-1px); }
    .hero-cta-ghost { display: inline-block; border: 1px solid rgba(255,255,255,0.25); color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 600; text-decoration: none; }
    .hero-sub { font-size: 13px; opacity: 0.4; margin-top: 10px; }

    /* MAP SECTION */
    .map-section { padding: 60px 20px 80px; background: linear-gradient(180deg, #111128, #0d0d1a); }
    .map-section > h2 { text-align: center; color: white; font-size: 32px; margin-bottom: 8px; }
    .map-section > p.map-sub { text-align: center; color: rgba(255,255,255,0.4); font-size: 15px; margin-bottom: 30px; }
    .map-toolbar { display: flex; justify-content: center; align-items: center; gap: 12px; margin-bottom: 20px; }
    .map-btn { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .map-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .map-btn.active { background: rgba(76,175,80,0.15); border-color: rgba(76,175,80,0.4); color: #4CAF50; }
    .map-breadcrumb { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px; font-size: 14px; color: rgba(255,255,255,0.4); }
    .map-breadcrumb span { cursor: pointer; transition: color 0.2s; }
    .map-breadcrumb span:hover { color: white; }
    .map-breadcrumb span.current { color: #4CAF50; font-weight: 700; cursor: default; }
    .map-breadcrumb .sep { opacity: 0.3; cursor: default; }

    .map-container { max-width: 1000px; margin: 0 auto; position: relative; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 30px; min-height: 500px; overflow: hidden; }

    /* US Map SVG */
    .us-map { width: 100%; height: auto; transition: opacity 0.4s ease; }
    .us-map .state { fill: #1e1e3a; stroke: #2a2a4a; stroke-width: 1; transition: all 0.3s ease; cursor: default; }
    .us-map .state.available { fill: #1a3a1a; stroke: #2d5a2d; cursor: pointer; }
    .us-map .state.available:hover { fill: #265e26; stroke: #4CAF50; }
    .us-map .state.active { fill: #2e7d32; stroke: #4CAF50; stroke-width: 2; }
    .us-map .state-label { font-size: 9px; fill: rgba(255,255,255,0.2); pointer-events: none; font-weight: 600; }
    .us-map .state.available .state-label, .us-map .state-label.available { fill: rgba(255,255,255,0.5); }

    /* FL detail view */
    .fl-detail { display: none; width: 100%; min-height: 460px; position: relative; }
    .fl-detail.visible { display: block; }
    .fl-detail .fl-map { width: 100%; height: auto; }
    .fl-detail .county { fill: #1e1e3a; stroke: #2a2a4a; stroke-width: 0.5; transition: all 0.3s; }
    .fl-detail .county.available { fill: #2e7d32; stroke: #4CAF50; stroke-width: 1.5; cursor: pointer; filter: drop-shadow(0 0 8px rgba(76,175,80,0.4)); }
    .fl-detail .county.available:hover { fill: #43a047; filter: drop-shadow(0 0 14px rgba(76,175,80,0.6)); }
    .fl-detail .county-label { font-size: 11px; fill: rgba(255,255,255,0.15); pointer-events: none; }
    .fl-detail .county-label.available { fill: white; font-weight: 700; font-size: 13px; }

    .coming-soon-tag { position: absolute; top: 20px; right: 20px; background: rgba(255,171,0,0.15); color: #ffab00; padding: 6px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; border: 1px solid rgba(255,171,0,0.3); }

    /* Volusia popup */
    .county-popup { display: none; position: absolute; background: #1a1a2e; border: 1px solid rgba(76,175,80,0.3); border-radius: 12px; padding: 24px; width: 320px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); z-index: 10; }
    .county-popup.visible { display: block; }
    .county-popup h3 { color: white; font-size: 20px; margin-bottom: 4px; }
    .county-popup .county-state { color: #4CAF50; font-size: 13px; font-weight: 600; margin-bottom: 14px; }
    .county-popup .popup-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .county-popup .popup-stat { background: rgba(255,255,255,0.04); padding: 10px; border-radius: 8px; }
    .county-popup .popup-stat .pval { font-size: 22px; font-weight: 800; color: white; }
    .county-popup .popup-stat .plbl { font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.5px; }
    .county-popup .popup-cta { display: block; background: #4CAF50; color: white; text-align: center; padding: 12px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; transition: background 0.2s; }
    .county-popup .popup-cta:hover { background: #43a047; }
    .county-popup .popup-close { position: absolute; top: 10px; right: 14px; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 18px; background: none; border: none; }

    /* HOW IT WORKS */
    .how-section { padding: 80px 20px; background: #111128; }
    .how-section h2 { text-align: center; color: white; font-size: 36px; margin-bottom: 15px; }
    .how-section > p { text-align: center; color: rgba(255,255,255,0.4); font-size: 16px; margin-bottom: 60px; }
    .how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1000px; margin: 0 auto; }
    .how-card { text-align: center; padding: 35px 25px; background: rgba(255,255,255,0.03); border-radius: 14px; border: 1px solid rgba(255,255,255,0.06); }
    .how-icon { font-size: 40px; margin-bottom: 16px; }
    .how-card h3 { color: white; margin-bottom: 10px; font-size: 18px; }
    .how-card p { color: rgba(255,255,255,0.45); font-size: 14px; }

    /* BETA CTA */
    .beta-section { padding: 80px 20px; background: #0d0d1a; text-align: center; }
    .beta-card { max-width: 700px; margin: 0 auto; background: linear-gradient(135deg, rgba(76,175,80,0.08), rgba(76,175,80,0.02)); border: 1px solid rgba(76,175,80,0.2); border-radius: 20px; padding: 50px 40px; }
    .beta-card h2 { color: white; font-size: 34px; margin-bottom: 12px; }
    .beta-card p { color: rgba(255,255,255,0.5); font-size: 16px; margin-bottom: 30px; }
    .beta-card .beta-live { display: inline-flex; align-items: center; gap: 8px; color: #4CAF50; font-weight: 700; font-size: 15px; margin-bottom: 25px; }
    .beta-card .beta-live .dot { width: 8px; height: 8px; border-radius: 50%; background: #4CAF50; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* ROADMAP */
    .roadmap { padding: 80px 20px; background: #111128; }
    .roadmap h2 { text-align: center; color: white; font-size: 36px; margin-bottom: 50px; }
    .roadmap-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1000px; margin: 0 auto; }
    .rm-card { padding: 25px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02); }
    .rm-card.live { border-color: rgba(76,175,80,0.3); background: rgba(76,175,80,0.05); }
    .rm-badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .rm-live { background: rgba(76,175,80,0.2); color: #4CAF50; }
    .rm-next { background: rgba(33,150,243,0.15); color: #42a5f5; }
    .rm-soon { background: rgba(255,171,0,0.15); color: #ffab00; }
    .rm-future { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.35); }
    .rm-card h4 { color: white; font-size: 15px; margin-bottom: 6px; }
    .rm-card p { color: rgba(255,255,255,0.35); font-size: 13px; }

    /* FOOTER */
    .footer { text-align: center; padding: 30px; color: rgba(255,255,255,0.2); font-size: 13px; background: #0d0d1a; border-top: 1px solid rgba(255,255,255,0.05); }

    @media (max-width: 900px) {
      .how-grid { grid-template-columns: 1fr; max-width: 400px; }
      .roadmap-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .hero h1 { font-size: 34px; }
      .nav { padding: 15px 20px; }
      .nav-links { gap: 12px; }
      .nav-links a { font-size: 13px; }
      .hero-buttons { flex-direction: column; align-items: center; }
      .roadmap-grid { grid-template-columns: 1fr; max-width: 350px; }
    }
  </style>
</head>
