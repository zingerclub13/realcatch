<!-- D3 + TopoJSON from CDN -->
<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3"></script>
<script>
var FL_FIPS = '12';
var VOLUSIA_FIPS = '12127';

// State abbreviation lookup
var stateAbbr = {
  1:'AL',2:'AK',4:'AZ',5:'AR',6:'CA',8:'CO',9:'CT',10:'DE',11:'DC',12:'FL',
  13:'GA',15:'HI',16:'ID',17:'IL',18:'IN',19:'IA',20:'KS',21:'KY',22:'LA',
  23:'ME',24:'MD',25:'MA',26:'MI',27:'MN',28:'MS',29:'MO',30:'MT',31:'NE',
  32:'NV',33:'NH',34:'NJ',35:'NM',36:'NY',37:'NC',38:'ND',39:'OH',40:'OK',
  41:'OR',42:'PA',44:'RI',45:'SC',46:'SD',47:'TN',48:'TX',49:'UT',50:'VT',
  51:'VA',53:'WA',54:'WV',55:'WI',56:'WY'
};

// Large enough states to show abbreviation labels
var labelStates = [6,12,13,17,22,26,27,28,36,37,39,42,47,48,55];

async function initMaps() {
  try {
    var results = await Promise.all([
      d3.json('https://cdn.jsdelivr.net/npm/us-atlas@3/states-albers-10m.json'),
      d3.json('https://cdn.jsdelivr.net/npm/us-atlas@3/counties-albers-10m.json')
    ]);
    var statesData = results[0];
    var countiesData = results[1];
  } catch (err) {
    document.getElementById('mapLoading').innerHTML = '<div style="color:#ff5252">Failed to load map. Please refresh.</div>';
    return;
  }

  var states = topojson.feature(statesData, statesData.objects.states);
  var path = d3.geoPath();

  // Hide loading, show map
  document.getElementById('mapLoading').style.display = 'none';
  document.getElementById('usaMap').style.display = '';

  // ========================
  // US STATES MAP
  // ========================
  var usaSvg = d3.select('#usaMap');

  // Render state paths
  usaSvg.selectAll('path.state')
    .data(states.features)
    .join('path')
    .attr('d', path)
    .attr('class', function(d) { return String(d.id) === FL_FIPS ? 'state available' : 'state'; })
    .on('click', function(e, d) { if (String(d.id) === FL_FIPS) zoomFlorida(); })
    .append('title')
    .text(function(d) { return (d.properties && d.properties.name) || stateAbbr[d.id] || ''; });

  // FL label with glow
  var flFeature = states.features.find(function(d) { return String(d.id) === FL_FIPS; });
  if (flFeature) {
    var flc = path.centroid(flFeature);
    usaSvg.append('text')
      .attr('x', flc[0]).attr('y', flc[1])
      .attr('text-anchor', 'middle')
      .attr('dominant-baseline', 'central')
      .attr('class', 'fl-label')
      .text('FL \u2726');
  }

  // Abbreviation labels for large states
  states.features.forEach(function(d) {
    if (labelStates.indexOf(+d.id) !== -1 && String(d.id) !== FL_FIPS) {
      var c = path.centroid(d);
      if (c[0] && c[1]) {
        usaSvg.append('text')
          .attr('x', c[0]).attr('y', c[1])
          .attr('text-anchor', 'middle')
          .attr('dominant-baseline', 'central')
          .style('font-size', '10px')
          .style('fill', 'rgba(255,255,255,0.15)')
          .style('font-weight', '600')
          .style('pointer-events', 'none')
          .text(stateAbbr[+d.id] || '');
      }
    }
  });

  // ========================
  // FLORIDA COUNTIES MAP
  // ========================
  var allCounties = topojson.feature(countiesData, countiesData.objects.counties);
  var flCounties = allCounties.features.filter(function(d) {
    return String(d.id).substring(0, 2) === FL_FIPS;
  });

  // Compute FL bounding box
  var flCollection = { type: 'FeatureCollection', features: flCounties };
  var bounds = path.bounds(flCollection);
  var x0 = bounds[0][0], y0 = bounds[0][1];
  var x1 = bounds[1][0], y1 = bounds[1][1];
  var pad = 30;

  var flSvg = d3.select('#flMapWrap')
    .append('svg')
    .attr('class', 'fl-map')
    .attr('viewBox', (x0 - pad) + ' ' + (y0 - pad) + ' ' + (x1 - x0 + pad * 2) + ' ' + (y1 - y0 + pad * 2));

  // Render county paths
  flSvg.selectAll('path.county')
    .data(flCounties)
    .join('path')
    .attr('d', path)
    .attr('class', function(d) { return String(d.id) === VOLUSIA_FIPS ? 'county available' : 'county'; })
    .on('click', function(e, d) {
      if (String(d.id) === VOLUSIA_FIPS) showVolusiaPopup(e);
    })
    .append('title')
    .text(function(d) { return String(d.id) === VOLUSIA_FIPS ? 'Volusia County — LIVE' : ''; });

  // Volusia label + pulsing glow
  var volusia = flCounties.find(function(d) { return String(d.id) === VOLUSIA_FIPS; });
  if (volusia) {
    var vc = path.centroid(volusia);

    // Label
    flSvg.append('text')
      .attr('x', vc[0]).attr('y', vc[1])
      .attr('text-anchor', 'middle')
      .attr('dominant-baseline', 'central')
      .attr('class', 'county-label')
      .text('VOLUSIA');

    // Pulsing dot
    var pulseG = flSvg.append('g');
    pulseG.append('circle')
      .attr('cx', vc[0]).attr('cy', vc[1] - 8)
      .attr('r', 2).attr('fill', '#4CAF50');

    var ring = pulseG.append('circle')
      .attr('cx', vc[0]).attr('cy', vc[1] - 8)
      .attr('r', 2).attr('fill', '#4CAF50').attr('opacity', 0.6);
    ring.append('animate')
      .attr('attributeName', 'r').attr('values', '2;8;2')
      .attr('dur', '2s').attr('repeatCount', 'indefinite');
    ring.append('animate')
      .attr('attributeName', 'opacity').attr('values', '0.6;0;0.6')
      .attr('dur', '2s').attr('repeatCount', 'indefinite');
  }
}

// ========================
// NAVIGATION
// ========================
function showUSA() {
  document.getElementById('usaMap').style.display = '';
  document.getElementById('usaMap').style.opacity = '1';
  document.getElementById('flDetail').classList.remove('visible');
  document.getElementById('btnUSA').classList.add('active');
  document.getElementById('btnFL').classList.remove('active');
  document.getElementById('breadcrumb').innerHTML = '<span class="current">United States</span>';
  closePopup();
}

function zoomFlorida() {
  var usaMap = document.getElementById('usaMap');
  usaMap.style.opacity = '0';
  setTimeout(function() {
    usaMap.style.display = 'none';
    document.getElementById('flDetail').classList.add('visible');
  }, 300);
  document.getElementById('btnFL').classList.add('active');
  document.getElementById('btnUSA').classList.remove('active');
  document.getElementById('breadcrumb').innerHTML =
    '<span onclick="showUSA()">United States</span>' +
    '<span class="sep">\u203A</span>' +
    '<span class="current">Florida</span>';
}

function showVolusiaPopup(e) {
  var popup = document.getElementById('volusiaPopup');
  var container = document.getElementById('mapContainer');
  var rect = container.getBoundingClientRect();
  var left = Math.min(e.clientX - rect.left + 20, rect.width - 340);
  var top = Math.min(e.clientY - rect.top - 60, rect.height - 300);
  if (left < 10) left = 10;
  if (top < 10) top = 10;
  popup.style.left = left + 'px';
  popup.style.top = top + 'px';
  popup.classList.add('visible');
}

function closePopup() {
  document.getElementById('volusiaPopup').classList.remove('visible');
}

// Close popup on outside click
document.addEventListener('click', function(e) {
  var popup = document.getElementById('volusiaPopup');
  if (popup.classList.contains('visible') && !popup.contains(e.target)) {
    var target = e.target;
    if (!target.classList || !target.classList.contains('available')) {
      closePopup();
    }
  }
});

// Initialize maps
initMaps();
</script>

