<script>
const usaMap = document.getElementById('usaMap');
const flDetail = document.getElementById('flDetail');
const btnUSA = document.getElementById('btnUSA');
const btnFL = document.getElementById('btnFL');
const breadcrumb = document.getElementById('breadcrumb');

function showUSA() {
  usaMap.style.display = '';
  usaMap.style.opacity = '1';
  flDetail.classList.remove('visible');
  btnUSA.classList.add('active');
  btnFL.classList.remove('active');
  breadcrumb.innerHTML = '<span class="current">United States</span>';
  closePopup();
}

function zoomFlorida() {
  usaMap.style.opacity = '0';
  setTimeout(() => {
    usaMap.style.display = 'none';
    flDetail.classList.add('visible');
  }, 300);
  btnFL.classList.add('active');
  btnUSA.classList.remove('active');
  breadcrumb.innerHTML = '<span onclick="showUSA()">United States</span><span class="sep">›</span><span class="current">Florida</span>';
}

function showVolusiaPopup(e) {
  const popup = document.getElementById('volusiaPopup');
  const container = document.getElementById('mapContainer');
  const rect = container.getBoundingClientRect();

  // Position popup near the click but keep it on screen
  let left = Math.min(e.clientX - rect.left + 20, rect.width - 340);
  let top = Math.min(e.clientY - rect.top - 60, rect.height - 300);
  if (left < 10) left = 10;
  if (top < 10) top = 10;

  popup.style.left = left + 'px';
  popup.style.top = top + 'px';
  popup.classList.add('visible');
}

function closePopup() {
  document.getElementById('volusiaPopup').classList.remove('visible');
}

// Click outside popup to close
document.addEventListener('click', function(e) {
  const popup = document.getElementById('volusiaPopup');
  if (popup.classList.contains('visible') && !popup.contains(e.target) && e.target.id !== 'volusia') {
    closePopup();
  }
});
</script>

