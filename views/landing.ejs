<script>
function filterDemo(btn) {
  document.querySelectorAll('.demo-filter').forEach(f => f.classList.remove('active'));
  btn.classList.add('active');
  const filter = btn.dataset.filter;
  const rows = document.querySelectorAll('#demoLeads tr');
  let visible = 0;
  rows.forEach(row => {
    const type = row.dataset.type;
    const score = parseInt(row.dataset.score);
    let show = filter === 'all' || (filter === 'score70' ? score >= 70 : type === filter);
    row.classList.toggle('hidden-row', !show);
    if (show) visible++;
  });
  const sl = document.getElementById('statLabel');
  const sv = document.getElementById('statVal');
  const sc = document.getElementById('statChange');
  if (filter === 'all') {
    sl.textContent = 'Hot Leads Today';
    sv.textContent = '23';
    sc.textContent = '↑ 8 from yesterday';
  } else {
    sl.textContent = btn.textContent.trim() + ' Leads';
    sv.textContent = visible;
    sc.textContent = 'Showing ' + visible + ' of 23 total';
  }
  document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
}
</script>
