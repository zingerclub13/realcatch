<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RealCatch — AI-Powered Real Estate Lead Intelligence</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #e0e0e0; line-height: 1.6; background: #0d0d1a; }
    a { color: inherit; }

    /* NAV */
    .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 40px; max-width: 1300px; margin: 0 auto; }
    .nav-logo { font-size: 26px; font-weight: 800; color: white; text-decoration: none; letter-spacing: -0.5px; }
    .nav-logo span { color: #4CAF50; }
    .nav-links { display: flex; align-items: center; gap: 25px; }
    .nav-links a { text-decoration: none; color: rgba(255,255,255,0.7); font-weight: 500; font-size: 15px; }
    .nav-links a.btn { background: #4CAF50; color: white; padding: 10px 22px; border-radius: 6px; font-weight: 600; }

    /* HERO */
    .hero { text-align: center; padding: 70px 20px 30px; background: linear-gradient(180deg, #0d0d1a 0%, #111128 100%); color: white; }
    .beta-badge { display: inline-block; background: rgba(255,171,0,0.15); color: #ffab00; padding: 6px 18px; border-radius: 20px; font-size: 13px; font-weight: 700; margin-bottom: 20px; border: 1px solid rgba(255,171,0,0.35); letter-spacing: 0.5px; }
    .hero h1 { font-size: 52px; max-width: 850px; margin: 0 auto 20px; line-height: 1.1; font-weight: 800; letter-spacing: -1px; }
    .hero h1 em { font-style: normal; color: #4CAF50; }
    .hero p.sub { font-size: 19px; opacity: 0.6; max-width: 640px; margin: 0 auto 35px; }
    .hero-buttons { display: flex; gap: 15px; justify-content: center; margin-bottom: 15px; }
    .hero-cta { display: inline-block; background: #4CAF50; color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
    .hero-cta:hover { background: #43a047; transform: translateY(-1px); }
    .hero-cta-ghost { display: inline-block; border: 1px solid rgba(255,255,255,0.25); color: white; padding: 15px 36px; border-radius: 8px; font-size: 17px; font-weight: 600; text-decoration: none; }
    .hero-sub { font-size: 13px; opacity: 0.4; margin-top: 10px; }

    /* MAP SECTION */
    .map-section { padding: 60px 20px 80px; background: linear-gradient(180deg, #111128, #0d0d1a); }
    .map-section > h2 { text-align: center; color: white; font-size: 32px; margin-bottom: 8px; }
    .map-section > p.map-sub { text-align: center; color: rgba(255,255,255,0.4); font-size: 15px; margin-bottom: 30px; }
    .map-toolbar { display: flex; justify-content: center; align-items: center; gap: 12px; margin-bottom: 20px; }
    .map-btn { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .map-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .map-btn.active { background: rgba(76,175,80,0.15); border-color: rgba(76,175,80,0.4); color: #4CAF50; }
    .map-breadcrumb { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px; font-size: 14px; color: rgba(255,255,255,0.4); }
    .map-breadcrumb span { cursor: pointer; transition: color 0.2s; }
    .map-breadcrumb span:hover { color: white; }
    .map-breadcrumb span.current { color: #4CAF50; font-weight: 700; cursor: default; }
    .map-breadcrumb .sep { opacity: 0.3; cursor: default; }

    .map-container { max-width: 1000px; margin: 0 auto; position: relative; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 30px; min-height: 500px; overflow: hidden; }

    /* US Map SVG */
    .us-map { width: 100%; height: auto; display: block; transition: opacity 0.4s ease; }
    .us-map .state { fill: #252550; stroke: #3a3a6a; stroke-width: 0.8; transition: all 0.3s ease; cursor: default; }
    .us-map .state:hover { fill: #2e2e5e; }
    .us-map .state.available { fill: #1b5e20; stroke: #4CAF50; stroke-width: 1.5; cursor: pointer; filter: drop-shadow(0 0 6px rgba(76,175,80,0.4)); }
    .us-map .state.available:hover { fill: #2e7d32; stroke: #66BB6A; filter: drop-shadow(0 0 12px rgba(76,175,80,0.6)); }
    .us-map .state-border { fill: none; stroke: #2a2a50; stroke-width: 0.6; pointer-events: none; }
    .us-map .fl-label { font-size: 14px; fill: #4CAF50; font-weight: 800; pointer-events: none; text-shadow: 0 0 10px rgba(76,175,80,0.6); }

    /* FL detail view */
    .fl-detail { display: none; width: 100%; min-height: 460px; position: relative; }
    .fl-detail.visible { display: block; }
    .fl-detail .fl-map { width: 100%; height: auto; display: block; }
    .fl-detail .county { fill: #252550; stroke: #3a3a6a; stroke-width: 0.5; transition: all 0.3s; cursor: default; }
    .fl-detail .county:hover { fill: #2e2e5e; }
    .fl-detail .county.available { fill: #2e7d32; stroke: #4CAF50; stroke-width: 1.5; cursor: pointer; filter: drop-shadow(0 0 8px rgba(76,175,80,0.4)); }
    .fl-detail .county.available:hover { fill: #43a047; filter: drop-shadow(0 0 14px rgba(76,175,80,0.6)); }
    .fl-detail .county-label { font-size: 5px; fill: white; font-weight: 700; pointer-events: none; }

    .coming-soon-tag { position: absolute; top: 20px; right: 20px; background: rgba(255,171,0,0.15); color: #ffab00; padding: 6px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; border: 1px solid rgba(255,171,0,0.3); z-index: 5; }

    /* Loading indicator */
    .map-loading { text-align: center; padding: 120px 20px; color: rgba(255,255,255,0.25); font-size: 15px; }
    .map-loading .spinner { display: inline-block; width: 24px; height: 24px; border: 2px solid rgba(255,255,255,0.1); border-top-color: #4CAF50; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 12px; }
